// A base configuration for src and tests, and also the config
// Visual Studio Code reads
{
    // Compiler options are mostly for the sub-configurations
    "compilerOptions": {
        // FORK: lib raised to ES2023 (upstream keeps es2021 for old-browser caution).
        // This fork's actual runtimes are Node 22 (server/tests), Electron 43 and
        // current Chromium (the premium CSS already requires :has() — Chrome 105+),
        // where every ES2022/ES2023 lib API (.at, Object.hasOwn, findLast, toSorted)
        // is long supported. `lib` only widens the TYPE surface — tsc never
        // polyfills lib methods, so the EMIT is unchanged. `target` deliberately
        // stays es2021: raising it flips useDefineForClassFields (class-field
        // semantics) for zero benefit here.
        "lib": ["dom", "es2023"],
        "incremental": true,
        "module": "commonjs",
        "strict": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "skipLibCheck": true,
        "target": "es2021",
        "types": ["node"],
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "rootDir": ".",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowUnreachableCode": false,
        "paths": {
            "@/*": ["./src/*"]
        },
        "plugins": [
            { "transform": "transformer-module" },
        ]

    },
    // This gives the VS Code IDE its magic.
    "include": [
        "**/*.ts",
    ],
}
