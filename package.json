{
  "name": "terraforming-mars",
  "version": "1.2.74",
  "description": "Terraforming Mars Game",
  "engines": {
    "node": "22.x"
  },
  "private": true,
  "main": "build/electron/main.js",
  "dependencies": {
    "@vueuse/core": "14.3.0",
    "ansi-escape-sequences": "^6.2.4",
    "chart.js": "^4.4.7",
    "console-stamp": "3.1.2",
    "cross-env": "^10.1.0",
    "dialog-polyfill": "^0.5.1",
    "dotenv": "^17.3.1",
    "gsap": "^3.15.0",
    "html-escaper": "^3.0.3",
    "markdown-it": "^14.2.0",
    "mnemonist": "^0.40.4",
    "motion-v": "^2.3.0",
    "prom-client": "^15.1.3",
    "simple-keyboard": "^3.8.158",
    "uuid": "^14.0.1",
    "velopack": "1.2.0",
    "vue": "^3.5.0",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.0.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.60.0",
    "@types/ansi-escape-sequences": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/html-escaper": "^3.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^7.14.7",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vue/test-utils": "^2.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.4",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "mocha": "^11.7.6",
    "mochapack": "^2.1.5",
    "png-to-ico": "^3.0.2",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "spectre.css": "^0.5.8",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vue-loader": "^17.0.0",
    "vue-tsc": "^3.3.6",
    "zlib": "^1.0.5"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.10.0",
    "pg": "^8.19.0"
  },
  "scripts": {
    "start": "node build/src/server/server.js",
    "start:prof": "node --prof build/src/server/server.js",
    "build": "npm run make:static && npm run build:server && npm run build:client",
    "build:client": "npm run make:cards && cross-env NODE_ENV=production webpack",
    "build:server": "tsc --build src/tsconfig.json && tsc-alias -p src/tsconfig.json",
    "build:test": "tsc --build tests/tsconfig.json",
    "build:tests": "tsc --build tests/tsconfig.json",
    "clean": "rimraf ./build/ ./build-desktop/ ./src/genfiles/",
    "lint": "npm run lint:server && npm run lint:i18n && npm run lint:client",
    "lint:client": "vue-tsc --noEmit -p tsconfig.vue-tsc.json",
    "lint:server": "eslint --cache src tests",
    "lint:i18n": "npx tsx src/tools/translation_audit.ts",
    "lint:fix": "eslint --fix src tests",
    "make:cards": "npx tsx src/server/tools/export_card_rendering.ts && npx tsx src/tools/make_card_art_manifest.ts",
    "make:css": "lessc src/styles/common.less build/styles.css && node src/server/tools/gzip.js",
    "convert:webp": "node scripts/convert-webp.cjs",
    "watch:less": "npx tsx scripts/watchcss.ts src/styles",
    "make:json": "npx tsx src/tools/make_static_json.ts",
    "card-art:extract": "tsx scripts/card-art/extract-card-art.ts",
    "make:static": "npm run make:css && npm run make:json",
    "test": "npm run test:server && npm run test:client",
    "test:server": "mocha --import=tsx --require tests/testing/setup.ts \"tests/*.spec.ts\" \"tests/!(client|integration|e2e)/**/*.spec.ts\"",
    "test:integration": "mocha --import=tsx --no-timeouts \"tests/integration/**/*.spec.ts\"",
    "test:postgresql": "mocha --import=tsx \"tests/integration/PostgreSQL.spec.ts\"",
    "test:client": "cross-env NODE_ENV=development mochapack --require tests/client/components/setup.ts \"tests/client/**/*.spec.ts\"",
    "test:client:watch": "cross-env NODE_ENV=development mochapack --watch --require tests/client/components/setup.ts \"tests/client/**/*.spec.ts\"",
    "dev:client": "cross-env NODE_ENV=development webpack --watch",
    "dev:server": "cross-env NODE_ENV=development tsx watch src/server/server.ts",
    "electron:build:main": "tsc -p electron/tsconfig.json",
    "electron:dev": "npm run electron:build:main && electron build/electron/main.js",
    "prepare": "node -e \"require('fs').existsSync('scripts/setup-hooks.mjs')&&require('child_process').execSync('node scripts/setup-hooks.mjs',{stdio:'inherit'})\"",
    "build:desktop": "npm run make:static && cross-env DESKTOP_BUILD=1 npm run build:client && npm run electron:build:main",
    "electron:desktop": "npm run build:desktop && cross-env TM_ELECTRON_LOAD=app electron build/electron/main.js",
    "electron:pack:dir": "npm run build:desktop && rimraf ./dist-desktop/ && electron-builder --dir --config electron-builder.yml",
    "pack:dir:win": "npm run build:desktop && rimraf ./dist-desktop/ && electron-builder --dir --win --config electron-builder.yml",
    "pack:dir:linux": "npm run build:desktop && rimraf ./dist-desktop/ && electron-builder --dir --linux --config electron-builder.yml",
    "pack:only:win": "rimraf ./dist-desktop/ && electron-builder --dir --win --config electron-builder.yml",
    "pack:only:linux": "rimraf ./dist-desktop/ && electron-builder --dir --linux --config electron-builder.yml",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/victor-zelinskiy/terraforming-mars.git"
  },
  "author": "Victor Zelinskiy",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/victor-zelinskiy/terraforming-mars/issues"
  },
  "homepage": "https://github.com/victor-zelinskiy/terraforming-mars#readme"
}
